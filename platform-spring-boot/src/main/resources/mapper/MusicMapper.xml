<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.example.platformspringboot.mapper.MusicMapper">

    <resultMap id="musicMap" type="Music">
        <id column="id" property="id"/>
        <result column="name" property="name"/>
        <result column="artist" property="artist"/>
        <result column="url" property="url"/>
        <result column="duration" property="duration"/>
        <result column="cover_url" property="coverUrl"/>
        <result column="create_time" property="createTime"/>
    </resultMap>

    <select id="listAll" resultMap="musicMap">SELECT * FROM music ORDER BY id</select>
    <select id="findById" resultMap="musicMap">SELECT * FROM music WHERE id=#{id}</select>
</mapper>